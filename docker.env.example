# Optional: override Docker Compose defaults (local Postgres is used if you omit these).
# Neon: Dashboard -> Connection string -> JDBC
# SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# At least 32 characters; use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Optional: Stripe (RON) for payments
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Browsers calling http://localhost:3000 (frontend) -> CORS for API
APP_FRONTEND_ORIGIN=http://localhost:3000

# Set true if you implement real email confirmation
APP_EMAIL_CONFIRMATION_REQUIRED=false
